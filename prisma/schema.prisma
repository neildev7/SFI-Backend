// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------
// ENUMS (Listas de valores fixos)
// --------------------------------------------------
enum Role {
  ADMIN
  PROFESSOR
  SECRETARIA
  COZINHA
  SISTEMA_IA
}

enum StatusPresenca {
  PRESENTE
  AUSENTE
  JUSTIFICADO
}

// --------------------------------------------------
// MODELOS (Tabelas)
// --------------------------------------------------

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senha        String   
  role         Role     @default(PROFESSOR)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("usuarios")
}

model Aluno {
  id              String       @id @default(uuid())
  nome            String
  matricula       String       @unique
  fotoTreinamento String?      @map("foto_treinamento")
  faceId          String?      @map("face_id")
  ativo           Boolean      @default(true)
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")
  
  turmas          TurmaAluno[]
  presencas       Presenca[]

  @@map("alunos")
}

model Turma {
  id           String       @id @default(uuid())
  nome         String
  anoLetivo    Int          @map("ano_letivo")
  ativo        Boolean      @default(true)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  
  alunos       TurmaAluno[]
  presencas    Presenca[]

  @@map("turmas")
}

model TurmaAluno {
  alunoId      String   @map("aluno_id")
  turmaId      String   @map("turma_id")
  ativo        Boolean  @default(true)
  
  aluno        Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma        Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@id([alunoId, turmaId])
  @@map("turmas_alunos")
}

model Disciplina {
  id           String     @id @default(uuid())
  nome         String
  codigo       String     @unique
  ativo        Boolean    @default(true)
  
  presencas    Presenca[]

  @@map("disciplinas")
}

model Presenca {
  id           String         @id @default(uuid())
  alunoId      String         @map("aluno_id")
  turmaId      String         @map("turma_id")
  disciplinaId String?        @map("disciplina_id")
  ativo        Boolean        @default(true)
  status       StatusPresenca @default(PRESENTE)
  dataHora     DateTime       @default(now()) @map("data_hora")
  
  aluno        Aluno          @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma        Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina   Disciplina?    @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)

  @@index([alunoId, dataHora]) 
  @@map("presencas")
}