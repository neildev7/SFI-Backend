// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------
// ENUMS (Listas de valores fixos)
// --------------------------------------------------
enum Role {
  ADMIN
  PROFESSOR
  SECRETARIA
  COZINHA
  SISTEMA_IA
}

enum StatusPresenca {
  PRESENTE
  AUSENTE
  JUSTIFICADO
}

// NOVO: Enum para rastrear a origem do registro
enum OrigemPresenca {
  FACIAL
  MANUAL
}

enum Turno {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}

enum AcaoAudit {
  CREATE
  UPDATE
  DELETE
  LOGIN
}

// --------------------------------------------------
// MODELOS (Tabelas)
// --------------------------------------------------

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senha        String   
  role         Role     @default(PROFESSOR)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  auditLogs    AuditLog[]
  @@map("usuarios")
}

model Aluno {
  id              String       @id @default(uuid())
  nome            String
  matricula       String       @unique
  fotoTreinamento String?      @map("foto_treinamento")
  faceId          String?      @map("face_id")
  ativo           Boolean      @default(true)
  criadoEm        DateTime     @default(now()) @map("criado_em")
  atualizadoEm    DateTime     @updatedAt @map("atualizado_em")
  
  turmas          TurmaAluno[]
  presencas       Presenca[]

  @@map("alunos")
}

model AuditLog {
  id           String    @id @default(uuid())
  usuarioId    String?   @map("usuario_id") // Pode ser nulo se a ação for automática (ex: IA)
  acao         AcaoAudit
  entidade     String    // Qual tabela foi mexida? Ex: "Aluno", "Presenca"
  entidadeId   String?   @map("entidade_id") // Qual o ID do registro alterado?
  dadosAntigos Json?     @map("dados_antigos") // Como era antes (formato JSON)
  dadosNovos   Json?     @map("dados_novos")   // Como ficou depois (formato JSON)
  ip           String?   // Rastreio de onde veio a requisição
  criadoEm     DateTime  @default(now()) @map("criado_em")

  usuario      Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Horario {
  id           String     @id @default(uuid())
  turmaId      String     @map("turma_id")
  disciplinaId String     @map("disciplina_id")
  diaSemana    DiaSemana  @map("dia_semana")
  horaInicio   String     @map("hora_inicio") // Vamos usar String no formato "07:30" para facilitar a comparação no Node
  horaFim      String     @map("hora_fim")    // Formato "11:30"
  ativo        Boolean    @default(true)

  turma        Turma      @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@map("horarios")
}

model Turma {
  id           String       @id @default(uuid())
  nome         String
  anoLetivo    Int          @map("ano_letivo")
  turno        Turno        @default(MANHA)
  ativo        Boolean      @default(true)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  
  alunos       TurmaAluno[]
  presencas    Presenca[]
  horarios     Horario[]    // <--- FALTAVA ESSA LINHA

  @@map("turmas")
}

model TurmaAluno {
  alunoId      String   @map("aluno_id")
  turmaId      String   @map("turma_id")
  ativo        Boolean  @default(true)
  
  aluno        Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma        Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@id([alunoId, turmaId])
  @@map("turmas_alunos")
}

model Disciplina {
  id           String     @id @default(uuid())
  nome         String
  codigo       String     @unique
  ativo        Boolean    @default(true)
  
  presencas    Presenca[]
  horarios     Horario[]  // <--- FALTAVA ESSA LINHA

  @@map("disciplinas")
}

model Presenca {
  id           String         @id @default(uuid())
  alunoId      String         @map("aluno_id")
  turmaId      String         @map("turma_id")
  disciplinaId String?        @map("disciplina_id")
  status       StatusPresenca @default(PRESENTE)
  
  // NOVOS CAMPOS AQUI
  origem       OrigemPresenca @default(MANUAL)
  faceScore    Float?         @map("face_score")
  
  dataHora     DateTime       @default(now()) @map("data_hora")
  
  aluno        Aluno          @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma        Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina   Disciplina?    @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)

  @@index([alunoId, dataHora]) 
  @@map("presencas")
}