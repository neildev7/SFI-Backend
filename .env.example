# ==========================================
# CONFIGURAÇÕES DO SERVIDOR
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# BANCO DE DADOS
# ==========================================
# Substitua USUARIO, SENHA e NOME_DO_BANCO pelas suas credenciais do PostgreSQL
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO?schema=public"

# ==========================================
# SEGURANÇA JWT 
# ==========================================
# ATENÇÃO: Nunca suba as chaves reais para o repositório.
# Utilize uma string longa e complexa em produção (ex: um hash SHA-256)
JWT_SECRET=insira_uma_chave_secreta_longa_e_segura_aqui
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=insira_uma_chave_refresh_longa_e_segura_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# INTEGRAÇÃO IA (Python)
# ==========================================
PYTHON_API_URL=http://localhost:5000
# Chave de comunicação Server-to-Server
IA_API_KEY=insira_a_chave_de_comunicacao_da_ia_aqui
IA_MIN_CONFIDENCE_SCORE=0.85

# ==========================================
# CORS & RATE LIMITING
# ==========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==========================================
# SMTP (E-mail Transacional)
# ==========================================
# Credenciais do serviço de envio de e-mails (ex: Mailtrap para dev, SendGrid para prod)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=insira_seu_usuario_smtp_aqui
SMTP_PASS=insira_sua_senha_smtp_aqui