# ==========================================
# CONFIGURAÇÕES DO SERVIDOR
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# BANCO DE DADOS
# ==========================================
DATABASE_URL="postgresql://postgres:senha123@localhost:5432/senai_presenca_db?schema=public"

# ==========================================
# SEGURANÇA JWT 
# ==========================================
# Utilize uma string longa e complexa em produção (ex: SHA-256 hash)
JWT_SECRET=super_chave_secreta_jwt_senai_2026_exemplo
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=chave_refresh_secreta_jwt_senai_exemplo
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# INTEGRAÇÃO IA (Python)
# ==========================================
PYTHON_API_URL=http://localhost:5000
IA_API_KEY=key_python_exemplo_a1b2c3d4e5f6
IA_MIN_CONFIDENCE_SCORE=0.85

# ==========================================
# CORS & RATE LIMITING
# ==========================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==========================================
# SMTP (E-mail Transacional)
# ==========================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=usuario_exemplo_mailtrap
